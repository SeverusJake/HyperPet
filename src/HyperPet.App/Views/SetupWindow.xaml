<Window x:Class="HyperPet.App.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HyperPet Setup"
        Width="420"
        Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Notification access" />

        <TextBlock Grid.Row="1"
                   Margin="0,18,0,0"
                   Text="HyperPet needs Windows notification access so your pet can react to alerts. Notification content stays on this device and is used only to show the pet alert bubble."
                   TextWrapping="Wrap" />

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Margin="0,0,0,16"
                   Foreground="#555555"
                   Text="Access has not been requested yet."
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button x:Name="RequestAccessButton"
                    Width="122"
                    Margin="0,0,10,0"
                    Content="Request access"
                    Click="OnRequestAccessClick" />
            <Button Width="86"
                    Content="Close"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
