<Window x:Class="HyperPet.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="480"
        Height="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Settings" />

        <CheckBox x:Name="ShowFullContentCheckBox"
                  Grid.Row="1"
                  Margin="0,20,0,0"
                  Content="Show full notification content"
                  IsChecked="True" />

        <CheckBox x:Name="StartWithWindowsCheckBox"
                  Grid.Row="2"
                  Margin="0,12,0,0"
                  Content="Start with Windows" />

        <CheckBox x:Name="OpenAppOnBubbleClickCheckBox"
                  Grid.Row="3"
                  Margin="0,8,0,0"
                  Content="Click bubble to open app" />

        <StackPanel Grid.Row="4"
                    Margin="0,12,0,0">
            <CheckBox x:Name="ReactToWindowsNotificationsCheckBox"
                      Content="React to Windows notifications" />
            <CheckBox x:Name="ReactToInAppNotificationsCheckBox"
                      Margin="0,8,0,0"
                      Content="React to in-app notifications (Zalo and other apps that don't use Windows toasts)" />
            <CheckBox x:Name="DebugModeCheckBox"
                      Margin="0,8,0,0"
                      Content="Debug" />
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Margin="0,18,0,0">
            <TextBlock Text="Pet behavior" />
            <ComboBox x:Name="PetBehaviorComboBox"
                      Margin="0,8,0,0"
                      SelectedIndex="0">
                <ComboBoxItem Content="Calm" />
                <ComboBoxItem Content="Desktop" />
            </ComboBox>
        </StackPanel>

        <Grid Grid.Row="6"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Alert duration (seconds)" />
                <TextBox x:Name="AlertDurationTextBox"
                         Margin="0,6,0,0"
                         Width="80"
                         HorizontalAlignment="Left"
                         PreviewTextInput="OnNumericPreviewTextInput"
                         Text="8" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Pet size (1-10, default 8)" />
                <TextBox x:Name="PetSizeTextBox"
                         Margin="0,6,0,0"
                         Width="80"
                         HorizontalAlignment="Left"
                         PreviewTextInput="OnNumericPreviewTextInput"
                         Text="8" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="7"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Windows poll interval (seconds, 5-600)" />
                <TextBox x:Name="WindowsPollIntervalTextBox"
                         Margin="0,6,0,0"
                         Width="80"
                         HorizontalAlignment="Left"
                         PreviewTextInput="OnNumericPreviewTextInput"
                         Text="30" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="In-app poll interval (seconds, 1-60)" />
                <TextBox x:Name="InAppPollIntervalTextBox"
                         Margin="0,6,0,0"
                         Width="80"
                         HorizontalAlignment="Left"
                         PreviewTextInput="OnNumericPreviewTextInput"
                         Text="2" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="9"
              Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Apps (matched by display name or AppUserModelId; case-insensitive substring). Uncheck to block."
                       TextWrapping="Wrap" />

            <ListBox x:Name="MessagingAppsListBox"
                     Grid.Row="1"
                     Margin="0,8,0,0"
                     MinHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox VerticalAlignment="Center"
                                      IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Grid.Column="1"
                                        Margin="8,0,0,0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding DisplayName}" />
                                <TextBlock FontSize="11"
                                           Foreground="#666"
                                           Text="{Binding PatternsDisplay}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewAppNameTextBox"
                         ToolTip="Display name (e.g. Telegram)" />
                <TextBox x:Name="NewAppPatternsTextBox"
                         Grid.Column="1"
                         Margin="6,0,0,0"
                         ToolTip="Match patterns, comma-separated" />
                <Button Grid.Column="2"
                        Margin="6,0,0,0"
                        Padding="12,2"
                        Content="Add"
                        Click="OnAddMessagingAppClick" />
            </Grid>

            <Button Grid.Row="3"
                    Margin="0,6,0,0"
                    HorizontalAlignment="Left"
                    Padding="12,2"
                    Content="Remove selected"
                    Click="OnRemoveMessagingAppClick" />
        </Grid>

        <StackPanel Grid.Row="10"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="86"
                    Margin="0,0,8,0"
                    Content="Save"
                    Click="OnSaveClick" />
            <Button Width="86"
                    Margin="0,0,8,0"
                    Content="Apply"
                    Click="OnApplyClick" />
            <Button Width="86"
                    Content="Close"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
