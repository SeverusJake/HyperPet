<Window x:Class="HyperPet.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pets="clr-namespace:HyperPet.Core.Pets;assembly=HyperPet.Core"
        Title="Settings"
        Width="500"
        Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Settings" />

        <TabControl Grid.Row="1"
                    Margin="0,14,0,0">
            <!-- ============================ GENERAL ============================ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="ShowFullContentCheckBox"
                                  Content="Show full notification content"
                                  IsChecked="True" />

                        <CheckBox x:Name="StartWithWindowsCheckBox"
                                  Margin="0,10,0,0"
                                  Content="Start with Windows" />

                        <CheckBox x:Name="OpenAppOnBubbleClickCheckBox"
                                  Margin="0,8,0,0"
                                  Content="Click bubble to open app"
                                  IsChecked="True" />

                        <CheckBox x:Name="ReactToWindowsNotificationsCheckBox"
                                  Margin="0,12,0,0"
                                  Content="React to Windows notifications" />

                        <CheckBox x:Name="ReactToInAppNotificationsCheckBox"
                                  Margin="0,8,0,0"
                                  Content="React to in-app notifications (Zalo and other apps that don't use Windows toasts)" />

                        <CheckBox x:Name="AutoUpdateCheckBox"
                                  Margin="0,8,0,0"
                                  Content="Auto-update (check on launch)" />

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Pet behavior" />
                            <ComboBox x:Name="PetBehaviorComboBox"
                                      Margin="0,6,0,0"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Calm" />
                                <ComboBoxItem Content="Running" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================== APPS ============================== -->
            <TabItem Header="Apps">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Apps (matched by display name or AppUserModelId; case-insensitive substring). Uncheck to block."
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="1"
                                Margin="0,8,0,0"
                                Orientation="Horizontal">
                        <Button Padding="10,2"
                                Content="Select all"
                                Click="OnSelectAllAppsClick" />
                        <Button Margin="6,0,0,0"
                                Padding="10,2"
                                Content="Unselect all"
                                Click="OnUnselectAllAppsClick" />
                    </StackPanel>

                    <ListBox x:Name="MessagingAppsListBox"
                             Grid.Row="2"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox VerticalAlignment="Center"
                                              IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Column="1"
                                                Margin="8,0,0,0">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock FontSize="11"
                                                   Foreground="#666"
                                                   Text="{Binding PatternsDisplay}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="3"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewAppNameTextBox"
                                 ToolTip="Display name (e.g. Telegram)" />
                        <TextBox x:Name="NewAppPatternsTextBox"
                                 Grid.Column="1"
                                 Margin="6,0,0,0"
                                 ToolTip="Match patterns, comma-separated" />
                        <Button Grid.Column="2"
                                Margin="6,0,0,0"
                                Padding="12,2"
                                Content="Add"
                                Click="OnAddMessagingAppClick" />
                    </Grid>

                    <Button Grid.Row="4"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Padding="12,2"
                            Content="Remove selected"
                            Click="OnRemoveMessagingAppClick" />
                </Grid>
            </TabItem>

            <!-- ============================== STATE ============================= -->
            <TabItem Header="State">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Animation playback speed (frames per second, 1-60) per sprite state."
                               TextWrapping="Wrap" />

                    <Grid Grid.Row="1"
                          Margin="0,10,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="State"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="Speed"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2"
                                   Margin="6,0,0,0"
                                   Text="Mode"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3"
                                   Margin="8,0,0,0"
                                   Text=""
                                   FontWeight="SemiBold" />
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="StateSpeedItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding DisplayName}" />
                                        <TextBox Grid.Column="1"
                                                 Width="56"
                                                 HorizontalAlignment="Left"
                                                 PreviewTextInput="OnNumericPreviewTextInput"
                                                 Text="{Binding Fps, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="2"
                                                  Margin="6,0,0,0"
                                                  Width="100"
                                                  HorizontalAlignment="Left"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="{Binding PlayMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="Forward"
                                                          Tag="{x:Static pets:PlayMode.Forward}" />
                                            <ComboBoxItem Content="Reverse"
                                                          Tag="{x:Static pets:PlayMode.Reverse}" />
                                            <ComboBoxItem Content="Ping-pong"
                                                          Tag="{x:Static pets:PlayMode.PingPong}" />
                                        </ComboBox>
                                        <Button Grid.Column="3"
                                                Margin="8,0,0,0"
                                                Padding="8,1"
                                                Content="Reset"
                                                Click="OnResetStateSpeedClick" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ============================ ADVANCED ============================ -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="DebugModeCheckBox"
                                  Content="Debug" />

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Alert duration (seconds)" />
                            <TextBox x:Name="AlertDurationTextBox"
                                     Margin="0,6,0,0"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     PreviewTextInput="OnNumericPreviewTextInput"
                                     Text="8" />
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Pet size (1-10, default 8)" />
                            <TextBox x:Name="PetSizeTextBox"
                                     Margin="0,6,0,0"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     PreviewTextInput="OnNumericPreviewTextInput"
                                     Text="8" />
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Running speed (1-20, default 2)" />
                            <TextBox x:Name="RunningSpeedTextBox"
                                     Margin="0,6,0,0"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     PreviewTextInput="OnNumericPreviewTextInput"
                                     Text="2" />
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Windows poll interval (seconds, 5-600)" />
                            <TextBox x:Name="WindowsPollIntervalTextBox"
                                     Margin="0,6,0,0"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     PreviewTextInput="OnNumericPreviewTextInput"
                                     Text="30" />
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="In-app poll interval (seconds, 1-60)" />
                            <TextBox x:Name="InAppPollIntervalTextBox"
                                     Margin="0,6,0,0"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     PreviewTextInput="OnNumericPreviewTextInput"
                                     Text="2" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================== ABOUT ============================= -->
            <TabItem Header="About">
                <StackPanel Margin="12">
                    <TextBlock x:Name="AboutVersionText"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#666"
                               Text="A desktop pet that reacts to your notifications." />

                    <Button x:Name="CheckUpdateButton"
                            Margin="0,16,0,0"
                            Padding="12,4"
                            HorizontalAlignment="Left"
                            Content="Check for update"
                            Click="OnCheckForUpdateClick" />

                    <TextBlock x:Name="UpdateStatusText"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="#444" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="86"
                    Content="Default"
                    Click="OnDefaultClick" />

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Width="86"
                        Margin="0,0,8,0"
                        Content="Close"
                        Click="OnCloseClick" />
                <Button x:Name="ApplyButton"
                        Width="86"
                        Margin="0,0,8,0"
                        Content="Apply"
                        IsEnabled="False"
                        Click="OnApplyClick" />
                <Button x:Name="SaveButton"
                        Width="86"
                        Content="Save"
                        IsEnabled="False"
                        Click="OnSaveClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
