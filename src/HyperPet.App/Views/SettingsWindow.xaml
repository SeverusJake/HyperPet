<Window x:Class="HyperPet.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="460"
        Height="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Settings" />

        <CheckBox x:Name="ShowFullContentCheckBox"
                  Grid.Row="1"
                  Margin="0,20,0,0"
                  Content="Show full notification content"
                  IsChecked="True" />

        <CheckBox x:Name="StartWithWindowsCheckBox"
                  Grid.Row="2"
                  Margin="0,12,0,0"
                  Content="Start with Windows" />

        <CheckBox x:Name="OnlyMessagingAppsCheckBox"
                  Grid.Row="3"
                  Margin="0,12,0,0"
                  Content="Only react to messaging apps" />

        <CheckBox x:Name="OpenAppOnBubbleClickCheckBox"
                  Grid.Row="4"
                  Margin="0,8,0,0"
                  Content="Click bubble to open app" />

        <CheckBox x:Name="EnableFrameControlsCheckBox"
                  Grid.Row="5"
                  Margin="0,8,0,0"
                  Content="Enable frame controls (F1 prev, F2 next, F3 pause)" />

        <StackPanel Grid.Row="6"
                    Margin="0,18,0,0">
            <TextBlock Text="Pet behavior" />
            <ComboBox x:Name="PetBehaviorComboBox"
                      Margin="0,8,0,0"
                      SelectedIndex="0">
                <ComboBoxItem Content="Calm" />
                <ComboBoxItem Content="Desktop" />
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="7"
                    Margin="0,18,0,0">
            <TextBlock Text="Alert duration" />
            <Slider x:Name="AlertDurationSlider"
                    Margin="0,8,0,0"
                    Minimum="3"
                    Maximum="30"
                    Value="8"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    TickPlacement="BottomRight" />
        </StackPanel>

        <Grid Grid.Row="8"
              Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Messaging apps (matched by display name or AppUserModelId; case-insensitive substring)"
                       TextWrapping="Wrap" />

            <ListBox x:Name="MessagingAppsListBox"
                     Grid.Row="1"
                     Margin="0,8,0,0"
                     MinHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox VerticalAlignment="Center"
                                      IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Grid.Column="1"
                                        Margin="8,0,0,0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding DisplayName}" />
                                <TextBlock FontSize="11"
                                           Foreground="#666"
                                           Text="{Binding PatternsDisplay}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewAppNameTextBox"
                         ToolTip="Display name (e.g. Telegram)" />
                <TextBox x:Name="NewAppPatternsTextBox"
                         Grid.Column="1"
                         Margin="6,0,0,0"
                         ToolTip="Match patterns, comma-separated" />
                <Button Grid.Column="2"
                        Margin="6,0,0,0"
                        Padding="12,2"
                        Content="Add"
                        Click="OnAddMessagingAppClick" />
            </Grid>

            <Button Grid.Row="3"
                    Margin="0,6,0,0"
                    HorizontalAlignment="Left"
                    Padding="12,2"
                    Content="Remove selected"
                    Click="OnRemoveMessagingAppClick" />
        </Grid>

        <Button Grid.Row="9"
                Width="86"
                HorizontalAlignment="Right"
                Content="Close"
                Click="OnCloseClick" />
    </Grid>
</Window>
